# BambooHR (optional unless using /api/bamboohr/*)
BAMBOOHR_COMPANY=
BAMBOOHR_API_KEY=

# Slack (optional unless using /api/slack/*)
SLACK_BOT_TOKEN=

# Optional convenience for Slack probe endpoints/scripts
SLACK_GENERAL_CHANNEL_ID=
SLACK_RANDOM_CHANNEL_ID=

# Server
PORT=4000

# MongoDB (optional)
# Example: mongodb://localhost:27017/intellihr
MONGODB_URI=

# Multi-tenant stub (optional): used when requests don't send x-org-id
DEFAULT_ORG_ID=demo

# Google Calendar (optional unless using /api/calendar/google/*)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/google/oauth/callback

# Optional: override where tokens are persisted (defaults to backend/.google_tokens.json)
GOOGLE_TOKEN_PATH=

# Optional: comma-separated scopes (default is Calendar read-only)
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar.readonly
